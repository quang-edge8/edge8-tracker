{
  "name": "edge8-tracker-phase1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "edge8-tracker — GitHub App webhook capture + mint engine",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "seed": "tsx src/seed.ts",
    "reparse": "tsx src/reparse.ts",
    "remint": "tsx src/remint.ts",
    "gen-secret": "tsx src/gen-secret.ts",
    "inspect": "tsx src/inspect.ts",
    "issue-key": "tsx scripts/issue-key.ts",
    "verify-db": "tsx scripts/verify-db.ts",
    "test": "tsx --test tests/mint.test.ts tests/pairing.test.ts tests/classify.test.ts tests/parse.test.ts",
    "test:serial": "tsx --test --test-concurrency=1 tests/mint.test.ts tests/pairing.test.ts tests/classify.test.ts tests/parse.test.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^7.1.3",
    "express": "^4.21.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
