# Copy to .env for local dev. The real .env is gitignored — never commit it.
# On Vercel, set these as Environment Variables (record every change here + README).

# GitHub App credentials
APP_ID=
WEBHOOK_SECRET=
# Local dev: path to the .pem file (gitignored under keys/)
PRIVATE_KEY_PATH=keys/app.private-key.pem
# Vercel: paste the FULL PEM content instead (\n-escaped is accepted)
# GITHUB_APP_PRIVATE_KEY=

# Storage backend:
#  - unset  -> local SQLite at data/capture.db (DB_PATH overrides)
#  - set    -> Supabase Postgres, schema "tracker" (use the transaction pooler, port 6543)
# TRACKER_DB_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Admin API token — protects POST/GET/DELETE /api/admin/keys (issue/list/revoke keys
# over HTTP after deploy). Generate a long random value; set it on Vercel too.
ADMIN_TOKEN=

# Local server
PORT=3000
